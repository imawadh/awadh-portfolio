---
import PageLayout from '../layouts/PageLayout.astro';
import TerminalWindow from '../components/TerminalWindow.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { socials } from '../utils/socials';
import { featuredProjects } from '../data/projects';
import { resumeUrl } from '../utils/site';

const stats = [
  { key: 'dsa.solved', value: '1,000+', label: 'DSA problems solved', meter: 88 },
  { key: 'git.commits', value: '1,800+', label: 'GitHub commits', meter: 96 },
  { key: 'projects.shipped', value: '6', label: 'products shipped', meter: 72 },
  { key: 'iitm.cgpa', value: '8.27', label: 'CGPA · IIT Madras', meter: 83 },
];

const highlights = [
  { n: '01', key: 'role', value: 'Full Stack Developer Intern @ IAVerse' },
  { n: '02', key: 'studying', value: 'BS Data Science · IIT Madras' },
  { n: '03', key: 'location', value: 'Bengaluru, India · Remote-friendly' },
];

// Syntax-highlighted code card — token colours by key
const cls: Record<string, string> = {
  com: 'text-[var(--muted)] italic',
  kw: 'text-[var(--cyan)]',
  var: 'text-[var(--fg)]',
  pun: 'text-[var(--muted)]',
  prop: 'text-[var(--fg-dim)]',
  str: 'text-[var(--accent)]',
  num: 'text-[var(--amber)]',
  bool: 'text-[var(--amber)]',
};

const codeLines: { t: string; c: keyof typeof cls }[][] = [
  [{ t: '// the person behind the commits', c: 'com' }],
  [
    { t: 'const ', c: 'kw' },
    { t: 'developer', c: 'var' },
    { t: ' = {', c: 'pun' },
  ],
  [
    { t: '  name', c: 'prop' },
    { t: ':      ', c: 'pun' },
    { t: "'Awadh Kishor Singh'", c: 'str' },
    { t: ',', c: 'pun' },
  ],
  [
    { t: '  alias', c: 'prop' },
    { t: ':     [', c: 'pun' },
    { t: "'imawadh'", c: 'str' },
    { t: ', ', c: 'pun' },
    { t: "'im_awadh_'", c: 'str' },
    { t: '],', c: 'pun' },
  ],
  [
    { t: '  role', c: 'prop' },
    { t: ':      ', c: 'pun' },
    { t: "'Full Stack Developer'", c: 'str' },
    { t: ',', c: 'pun' },
  ],
  [
    { t: '  edu', c: 'prop' },
    { t: ':       ', c: 'pun' },
    { t: "'BS Data Science @ IIT Madras'", c: 'str' },
    { t: ',', c: 'pun' },
  ],
  [
    { t: '  base', c: 'prop' },
    { t: ':      ', c: 'pun' },
    { t: "'Bengaluru, India'", c: 'str' },
    { t: ',', c: 'pun' },
  ],
  [
    { t: '  stack', c: 'prop' },
    { t: ':     [', c: 'pun' },
    { t: "'Next.js'", c: 'str' },
    { t: ', ', c: 'pun' },
    { t: "'Node'", c: 'str' },
    { t: ', ', c: 'pun' },
    { t: "'Mongo'", c: 'str' },
    { t: '],', c: 'pun' },
  ],
  [
    { t: '  solved', c: 'prop' },
    { t: ':    ', c: 'pun' },
    { t: '1000', c: 'num' },
    { t: ',', c: 'pun' },
    { t: '   // DSA problems', c: 'com' },
  ],
  [
    { t: '  available', c: 'prop' },
    { t: ': ', c: 'pun' },
    { t: 'true', c: 'bool' },
    { t: ',', c: 'pun' },
  ],
  [{ t: '};', c: 'pun' }],
];
---

<PageLayout
  title="Awadh Kishor Singh | Full Stack Developer"
  description="Awadh Kishor Singh — Full Stack Developer in Bengaluru building production-ready web apps with React, Next.js, Node.js, and REST APIs. Data Science undergraduate at IIT Madras."
>
  <!-- ───────────── HERO ───────────── -->
  <section class="wrap pt-14 md:pt-20">
    <div class="grid gap-10 md:grid-cols-[1.45fr_1fr] md:items-center md:gap-12">
      <!-- LEFT: headline -->
      <div>
        <span class="eyebrow reveal reveal-1">portfolio v2.0</span>

        <h1 class="reveal reveal-2 mt-4 max-w-[16ch]">
          Full Stack Developer building
          <span class="text-[var(--accent)]">production-ready</span> web apps.
        </h1>

        <p class="reveal reveal-2 mt-5 max-w-[52ch] text-base leading-relaxed md:text-lg">
          I'm Awadh Kishor Singh — I design, build, and ship end-to-end web applications with
          React, Next.js, Node.js, and REST APIs. Data Science undergraduate at IIT Madras,
          and a developer who cares about clean architecture and what users never see.
        </p>
      </div>

      <!-- RIGHT: code card -->
      <div class="reveal reveal-3 card overflow-hidden">
        <div class="flex items-center gap-2 border-b border-[var(--border)] bg-[var(--surface)] px-4 py-2.5">
          <span
            class="inline-flex h-4 w-4 items-center justify-center rounded-[3px] bg-[var(--cyan)] font-mono text-[8px] font-bold text-[var(--bg)]"
          >
            TS
          </span>
          <span class="font-mono text-xs text-[var(--fg-dim)]">developer.ts</span>
          <span class="ml-auto inline-flex items-center gap-1.5 font-mono text-[0.68rem] text-[var(--accent)]">
            <span class="h-1.5 w-1.5 rounded-full bg-[var(--accent)]"></span>
            live
          </span>
        </div>
        <div class="overflow-x-auto p-4 md:p-5">
          <div class="font-mono text-[0.76rem] leading-[1.75] md:text-[0.8rem]">
            {
              codeLines.map((line, i) => (
                <div class="flex gap-3.5">
                  <span class="w-4 shrink-0 select-none text-right text-[var(--muted)] opacity-40">
                    {i + 1}
                  </span>
                  <span class="whitespace-pre">
                    {line.map((tok) => (
                      <span class={cls[tok.c]}>{tok.t}</span>
                    ))}
                  </span>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <!-- Terminal + photo -->
    <div class="reveal reveal-3 mt-6 grid gap-5 md:grid-cols-[1.5fr_1fr] md:items-stretch">
      <TerminalWindow title="awadh@portfolio: ~">
        <div class="flex flex-col gap-2.5 font-mono text-sm md:text-[0.95rem]">
          <p class="prompt">whoami</p>
          <p class="out text-[var(--fg)]">Awadh Kishor Singh — aka imawadh / im_awadh_</p>

          <p class="prompt mt-2">cat role.txt</p>
          <p class="out text-[var(--fg)]">Full Stack Developer · Data Science @ IIT Madras</p>

          <p class="prompt mt-2">./stack --list</p>
          <p class="out text-[var(--fg-dim)]">
            React · Next.js · Node.js · Express · MongoDB · PostgreSQL
          </p>

          <p class="prompt mt-2">echo $STATUS</p>
          <p class="out text-[var(--accent)]">
            available for full-stack &amp; SWE roles
            <span class="cursor"></span>
          </p>
        </div>
      </TerminalWindow>

      <!-- Photo as a terminal window -->
      <div class="term flex flex-col">
        <div class="term-bar">
          <span class="dot dot-r"></span>
          <span class="dot dot-y"></span>
          <span class="dot dot-g"></span>
          <span class="term-title">~/awadh/me.jpg</span>
        </div>
        <div class="relative flex-1">
          <img
            src="/awadh-about.webp"
            alt="Portrait of Awadh Kishor Singh"
            loading="eager"
            class="aspect-[4/5] h-full w-full object-cover object-center md:aspect-auto"
          />
          <span
            class="absolute bottom-3 left-3 rounded-md border border-[var(--border-bright)] bg-[rgba(10,13,18,0.85)] px-2.5 py-1 font-mono text-[0.7rem] text-[var(--accent)] backdrop-blur"
          >
            ● Bengaluru, IN
          </span>
        </div>
      </div>
    </div>

    <!-- CTAs -->
    <div class="reveal reveal-4 mt-8 flex flex-wrap gap-3">
      <a href="/projects" class="btn btn-primary">▸ view my work</a>
      <a href={resumeUrl} target="_blank" rel="noopener noreferrer" class="btn">↓ resume.pdf</a>
      <a href="/contact" class="btn">↳ get in touch</a>
    </div>

    <!-- Socials -->
    <div class="reveal reveal-4 mt-6 flex flex-wrap gap-2">
      {
        socials.map((social) => (
          <a href={social.url} target="_blank" rel="noopener noreferrer" class="chip">
            {social.label}
          </a>
        ))
      }
    </div>
  </section>

  <!-- ───────────── STATS + STATUS ───────────── -->
  <section class="wrap mt-20">
    <div class="flex items-center justify-between gap-4">
      <p class="prompt m-0 text-xs">cat ./stats.json</p>
      <span class="hidden font-mono text-[0.7rem] text-[var(--muted)] sm:inline">// the track record</span>
    </div>

    <div class="mt-4 grid grid-cols-2 gap-3 md:grid-cols-4">
      {
        stats.map((s) => (
          <div class="card group overflow-hidden p-5 transition-all duration-300 hover:-translate-y-1 hover:border-[var(--accent-2)]">
            <span class="block truncate font-mono text-[0.64rem] text-[var(--muted)] transition-colors duration-300 group-hover:text-[var(--accent)]">
              {s.key}
            </span>
            <span class="stat-num mt-1.5 block font-mono text-3xl font-bold leading-none text-[var(--accent)] md:text-4xl">
              {s.value}
            </span>
            <p class="m-0 mt-2.5 font-mono text-[0.72rem] uppercase tracking-wider text-[var(--muted)]">
              {s.label}
            </p>
            <div class="mt-3.5 h-[3px] w-full overflow-hidden rounded-full bg-[var(--border)]">
              <div
                class="meter-fill h-full rounded-full bg-[var(--accent)]"
                style={`width:${s.meter}%`}
              />
            </div>
          </div>
        ))
      }
    </div>

    <p class="prompt mb-3 mt-10 text-xs">whoami --status</p>
    <div class="grid gap-3 md:grid-cols-3">
      {
        highlights.map((h) => (
          <div class="card group flex items-center gap-3.5 p-5 transition-all duration-300 hover:-translate-y-0.5 hover:border-[var(--accent-2)]">
            <span class="grid h-10 w-10 shrink-0 place-items-center rounded-md border border-[var(--border-bright)] bg-[var(--bg-2)] font-mono text-sm font-bold text-[var(--accent)] transition-colors duration-300 group-hover:border-[var(--accent)]">
              {h.n}
            </span>
            <div class="min-w-0">
              <span class="font-mono text-[0.68rem] uppercase tracking-wider text-[var(--accent)]">
                {h.key}
              </span>
              <p class="m-0 mt-0.5 text-sm font-medium text-[var(--fg)]">{h.value}</p>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ───────────── FEATURED WORK ───────────── -->
  <section class="wrap mt-24">
    <div class="flex items-end justify-between gap-4">
      <div>
        <span class="eyebrow">featured work</span>
        <h2 class="mt-3">Selected projects</h2>
      </div>
      <a
        href="/projects"
        class="hidden shrink-0 font-mono text-sm text-[var(--fg-dim)] transition-colors hover:text-[var(--accent)] sm:inline"
      >
        all projects →
      </a>
    </div>

    <div class="mt-8 grid gap-5 md:grid-cols-2">
      {
        featuredProjects.map((p) => (
          <ProjectCard
            index={p.index}
            name={p.name}
            tagline={p.tagline}
            description={p.description}
            tags={p.tags}
            status={p.status}
            live={p.live}
            code={p.code}
            caseStudy={p.caseStudy}
          />
        ))
      }
    </div>

    <a
      href="/projects"
      class="mt-6 inline-flex font-mono text-sm text-[var(--fg-dim)] transition-colors hover:text-[var(--accent)] sm:hidden"
    >
      all projects →
    </a>
  </section>
</PageLayout>

<style>
  .stat-num {
    text-shadow: 0 0 22px var(--glow);
  }
  .meter-fill {
    transform-origin: left;
    animation: growbar 1.1s cubic-bezier(0.22, 1, 0.36, 1) 0.25s both;
  }
  @keyframes growbar {
    from {
      transform: scaleX(0);
    }
    to {
      transform: scaleX(1);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .meter-fill {
      animation: none;
    }
  }
</style>
