---
import PageLayout from '../layouts/PageLayout.astro';
import SkillCard from '../components/SkillCard.astro';

const skillsData = [
  {
    index: '01',
    category: 'Languages',
    command: 'ls ./languages',
    skills: ['Python', 'C++', 'Java', 'JavaScript (ES6+)', 'SQL', 'HTML5', 'CSS3'],
  },
  {
    index: '02',
    category: 'Frontend',
    command: 'ls ./frontend',
    skills: ['React.js', 'Next.js', 'Tailwind CSS', 'Responsive Web Design'],
  },
  {
    index: '03',
    category: 'Backend',
    command: 'ls ./backend',
    skills: ['Node.js', 'Express.js', 'Django', 'Flask', 'REST API Development'],
  },
  {
    index: '04',
    category: 'Databases',
    command: 'ls ./databases',
    skills: ['MongoDB', 'MySQL', 'PostgreSQL'],
  },
  {
    index: '05',
    category: 'Core CS',
    command: 'ls ./fundamentals',
    skills: [
      'Data Structures & Algorithms',
      'OOP',
      'System Design',
      'Scalable Architecture',
      'API Security',
    ],
  },
  {
    index: '06',
    category: 'Monitoring & Analytics',
    command: 'ls ./observability',
    skills: ['Mixpanel', 'PostHog', 'Google Analytics', 'Sentry'],
  },
  {
    index: '07',
    category: 'Tools & Platforms',
    command: 'ls ./tools',
    skills: ['Git', 'GitHub', 'Postman', 'Linux', 'VS Code', 'Vercel', 'Render'],
  },
];

const allSkills = skillsData.flatMap((c) => c.skills);
---

<PageLayout
  title="Skills & Technologies — Awadh Kishor Singh"
  description="The full tech stack of Awadh Kishor Singh — React, Next.js, Node.js, Express, MongoDB, PostgreSQL, Python, and the tools behind production web apps."
>
  <section class="wrap pt-14 md:pt-20">
    <span class="eyebrow reveal reveal-1">skills</span>
    <h1 class="reveal reveal-2 mt-4">./stack --all</h1>
    <p class="reveal reveal-2 mt-4 max-w-[60ch] text-base md:text-lg">
      The languages, frameworks, and tools I reach for across full-stack development — from
      shipping UI to securing APIs to monitoring what happens in production.
    </p>

    <div class="reveal reveal-3 mt-12 grid gap-4 md:grid-cols-2">
      {
        skillsData.map((group) => (
          <SkillCard
            index={group.index}
            category={group.category}
            command={group.command}
            skills={group.skills}
          />
        ))
      }
    </div>

    <!-- Marquee -->
    <div class="reveal reveal-4 mt-14">
      <p class="prompt mb-3 text-xs">echo $PATH</p>
      <div class="overflow-hidden rounded-xl border border-[var(--border)] bg-[var(--bg-2)] py-4">
        <div class="marquee-track flex gap-3">
          {allSkills.map((skill) => <span class="chip shrink-0 whitespace-nowrap">{skill}</span>)}
          {allSkills.map((skill) => <span class="chip shrink-0 whitespace-nowrap">{skill}</span>)}
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .marquee-track {
    width: max-content;
    animation: marquee 38s linear infinite;
  }
  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(calc(-50% - 0.375rem));
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
      flex-wrap: wrap;
    }
  }
</style>
