---
import PageLayout from '../../layouts/PageLayout.astro';
import TerminalWindow from '../../components/TerminalWindow.astro';

const facts = [
  { key: 'stack', value: 'Next.js · React · Node · Express · MongoDB · PostgreSQL' },
  { key: 'currently', value: 'Full Stack Developer Intern @ IAVerse (Remote)' },
  { key: 'education', value: 'BS Data Science, IIT Madras · CGPA 8.27' },
  { key: 'algorithms', value: '1,000+ DSA problems · LeetCode & Codeforces' },
];

const principles = [
  {
    title: 'Ship end-to-end',
    body: 'I work across the whole stack — UI, API, database, deployment — so a feature is done when it is live and working, not when the PR merges.',
  },
  {
    title: 'Build for scale',
    body: 'Scalable architecture, clean component systems, and API security are decisions I make early, not patches I add when something breaks.',
  },
  {
    title: 'Mind the invisible',
    body: 'Analytics, error monitoring, and performance budgets matter as much as the visible UI — they are how you actually know a product works.',
  },
];

const quickNav = [
  { label: 'experience', href: '/experience' },
  { label: 'projects', href: '/projects' },
  { label: 'skills', href: '/skills' },
  { label: 'contact', href: '/contact' },
];
---

<PageLayout
  title="About — Awadh Kishor Singh"
  description="About Awadh Kishor Singh — Full Stack Developer in Bengaluru and Data Science undergraduate at IIT Madras, building production-ready web applications end-to-end."
>
  <section class="wrap pt-14 md:pt-20">
    <span class="eyebrow reveal reveal-1">about</span>
    <h1 class="reveal reveal-2 mt-4">whoami</h1>
    <p class="reveal reveal-2 mt-4 max-w-[60ch] text-base md:text-lg">
      Full Stack Developer based in Bengaluru — building web apps that hold up with real users,
      real traffic, and real deadlines.
    </p>

    <div class="reveal reveal-3 mt-12 grid gap-8 md:grid-cols-[300px_1fr] md:items-start">
      <!-- Profile photo card -->
      <div class="term overflow-hidden md:sticky md:top-24">
        <div class="term-bar">
          <span class="dot dot-r"></span>
          <span class="dot dot-y"></span>
          <span class="dot dot-g"></span>
          <span class="term-title">~/awadh/profile.jpg</span>
        </div>
        <img
          src="/sitting-image.webp"
          alt="Awadh Kishor Singh"
          loading="eager"
          class="aspect-[3/4] w-full object-cover object-top"
        />
        <div class="flex items-center justify-between gap-3 border-t border-[var(--border)] bg-[var(--surface)] px-4 py-3">
          <div>
            <p class="m-0 font-mono text-sm text-[var(--fg)]">Awadh Kishor Singh</p>
            <p class="m-0 font-mono text-xs text-[var(--muted)]">@imawadh</p>
          </div>
          <div class="inline-flex items-center gap-1.5">
            <span class="relative inline-flex h-2 w-2">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[var(--accent)] opacity-60"></span>
              <span class="relative inline-flex h-2 w-2 rounded-full bg-[var(--accent)]"></span>
            </span>
            <span class="font-mono text-[0.7rem] text-[var(--accent)]">open</span>
          </div>
        </div>
      </div>

      <!-- Bio -->
      <div class="flex flex-col gap-5">
        <p class="m-0 text-base leading-relaxed md:text-lg">
          I'm a Full Stack Developer and a Data Science undergraduate at
          <span class="link">IIT Madras</span>. I design, build, and ship production-ready web
          applications — currently as a Full Stack Developer Intern at
          <span class="text-[var(--accent)]">IAVerse</span>.
        </p>
        <p class="m-0 leading-relaxed text-[var(--fg-dim)]">
          My recent work spans a 1,600-page WordPress-to-Next.js migration at IAVerse, a freelance
          ed-tech platform serving 1,500+ daily active users, and a peer-to-peer marketplace live
          across four Indian cities. I work the whole stack: React and Next.js on the front,
          Node.js and Express REST APIs on the back, MongoDB and PostgreSQL for data, deployed on
          Vercel and Render.
        </p>
        <p class="m-0 leading-relaxed text-[var(--fg-dim)]">
          I care about the parts users never see — product analytics with Mixpanel and PostHog,
          error monitoring with Sentry, API security, and architecture that scales. Alongside
          building, I've solved 1,000+ Data Structures &amp; Algorithms problems on LeetCode and
          Codeforces, with a focus on Trees, Graphs, and Dynamic Programming.
        </p>

        <!-- Facts terminal -->
        <TerminalWindow title="cat ~/about/facts.txt" class="mt-2">
          <div class="flex flex-col gap-3 font-mono text-sm">
            {
              facts.map((f) => (
                <div class="flex flex-col gap-0.5 sm:flex-row sm:gap-3">
                  <span class="shrink-0 text-[var(--accent)] sm:w-28">{f.key}:</span>
                  <span class="text-[var(--fg-dim)]">{f.value}</span>
                </div>
              ))
            }
          </div>
        </TerminalWindow>
      </div>
    </div>

    <!-- Principles -->
    <div class="reveal reveal-4 mt-20">
      <span class="eyebrow">how i work</span>
      <h2 class="mt-3">Principles</h2>
      <div class="mt-8 grid gap-4 md:grid-cols-3">
        {
          principles.map((p, i) => (
            <div class="card p-6">
              <span class="font-mono text-sm text-[var(--muted)]">
                0{i + 1}
              </span>
              <h3 class="mt-2 text-base text-[var(--accent)]">{p.title}</h3>
              <p class="m-0 mt-2 text-sm leading-relaxed text-[var(--fg-dim)]">{p.body}</p>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Quick nav -->
    <div class="mt-16 flex flex-wrap gap-2.5">
      {
        quickNav.map((n) => (
          <a href={n.href} class="btn">
            {n.label} →
          </a>
        ))
      }
    </div>
  </section>
</PageLayout>
