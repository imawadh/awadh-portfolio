---
import PageLayout from '../../layouts/PageLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { personalProjects, freelanceProjects, projects } from '../../data/projects';
---

<PageLayout
  title="Projects — Awadh Kishor Singh"
  description="Projects by Awadh Kishor Singh — personal builds (Prescripto, Cryptofolio) and freelance client work (Axiora Learning, EVAA Enterprises, The SRS Classes, Prsnn)."
>
  <section class="wrap pt-14 md:pt-20">
    <span class="eyebrow reveal reveal-1">projects</span>
    <h1 class="reveal reveal-2 mt-4">ls ./projects</h1>
    <p class="reveal reveal-2 mt-4 max-w-[62ch] text-base md:text-lg">
      Full-stack applications and client websites built end-to-end — most live in production with
      real users. Each ships its own architecture, build, and deployment story.
    </p>

    <div class="reveal reveal-3 mt-6 flex flex-wrap gap-2">
      <span class="chip">{projects.length} projects</span>
      <span class="chip">{personalProjects.length} personal</span>
      <span class="chip">{freelanceProjects.length} freelance</span>
      <span class="chip">{projects.filter((p) => p.status === 'live').length} live</span>
    </div>

    <!-- ───────── PERSONAL ───────── -->
    <div class="reveal reveal-4 mt-16">
      <div class="flex items-end justify-between gap-4">
        <div>
          <span class="eyebrow">personal projects</span>
          <h2 class="mt-3">Built to learn &amp; ship</h2>
        </div>
        <span class="hidden font-mono text-xs text-[var(--muted)] sm:inline">
          {personalProjects.length} repos
        </span>
      </div>
      <p class="mt-3 max-w-[58ch] text-sm text-[var(--muted)]">
        Self-directed full-stack builds where I owned every architectural decision end-to-end.
      </p>
      <div class="mt-7 grid gap-5 md:grid-cols-2">
        {
          personalProjects.map((p) => (
            <ProjectCard
              index={p.index}
              name={p.name}
              tagline={p.tagline}
              description={p.description}
              tags={p.tags}
              status={p.status}
              live={p.live}
              code={p.code}
              caseStudy={p.caseStudy}
            />
          ))
        }
      </div>
    </div>

    <!-- ───────── FREELANCE ───────── -->
    <div class="mt-20">
      <div class="flex items-end justify-between gap-4">
        <div>
          <span class="eyebrow">freelance &amp; client work</span>
          <h2 class="mt-3">Shipped for clients</h2>
        </div>
        <span class="hidden font-mono text-xs text-[var(--muted)] sm:inline">
          {freelanceProjects.length} clients
        </span>
      </div>
      <p class="mt-3 max-w-[58ch] text-sm text-[var(--muted)]">
        Independent contract work — production websites and platforms delivered for real
        businesses and live users.
      </p>
      <div class="mt-7 grid gap-5 md:grid-cols-2">
        {
          freelanceProjects.map((p) => (
            <ProjectCard
              index={p.index}
              name={p.name}
              tagline={p.tagline}
              description={p.description}
              tags={p.tags}
              status={p.status}
              live={p.live}
              code={p.code}
              caseStudy={p.caseStudy}
            />
          ))
        }
      </div>
    </div>

    <!-- CTA -->
    <div class="mt-16 card flex flex-col gap-4 p-8 md:flex-row md:items-center md:justify-between">
      <div>
        <span class="eyebrow">open for work</span>
        <h2 class="mt-2 text-xl md:text-2xl">Have something to build?</h2>
        <p class="m-0 mt-2 max-w-md text-sm text-[var(--fg-dim)]">
          I'm open to full-stack roles and a small number of freelance engagements.
        </p>
      </div>
      <a href="/contact" class="btn btn-primary shrink-0">↳ start a conversation</a>
    </div>
  </section>
</PageLayout>
