---
import PageLayout from '../layouts/PageLayout.astro';
import TerminalWindow from '../components/TerminalWindow.astro';
import { socials } from '../utils/socials';

const channels = [
  {
    key: 'email',
    value: 'awadhkishorsingh241@gmail.com',
    href: 'mailto:awadhkishorsingh241@gmail.com',
    copy: true,
  },
  { key: 'phone', value: '+91 79850 00241', href: 'tel:+917985000241', copy: false },
  { key: 'location', value: 'Bengaluru, Karnataka, India', href: null, copy: false },
];

const mailtoCompose =
  'mailto:awadhkishorsingh241@gmail.com?subject=Let%27s%20work%20together&body=Hi%20Awadh%2C%0A%0A';
---

<PageLayout
  title="Contact — Awadh Kishor Singh"
  description="Get in touch with Awadh Kishor Singh — Full Stack Developer in Bengaluru — for full-stack roles, freelance projects, or collaborations."
>
  <section class="wrap pt-14 md:pt-20">
    <span class="eyebrow reveal reveal-1">contact</span>
    <h1 class="reveal reveal-2 mt-4">./say-hello</h1>
    <p class="reveal reveal-2 mt-4 max-w-[58ch] text-base md:text-lg">
      Open to full-stack and software engineering roles, freelance builds, and good
      conversations. The fastest way to reach me is email — I usually reply within a day.
    </p>

    <div class="reveal reveal-3 mt-12 grid gap-6 md:grid-cols-[1fr_1fr]">
      <!-- Channels -->
      <div class="flex flex-col gap-3">
        {
          channels.map((c) => (
            <div class="card flex items-center justify-between gap-4 p-5">
              <div class="min-w-0">
                <span class="font-mono text-[0.72rem] uppercase tracking-wider text-[var(--accent)]">
                  {c.key}
                </span>
                {c.href ? (
                  <a
                    href={c.href}
                    class="mt-1 block break-all font-mono text-sm text-[var(--fg)] transition-colors hover:text-[var(--accent)]"
                  >
                    {c.value}
                  </a>
                ) : (
                  <p class="m-0 mt-1 font-mono text-sm text-[var(--fg)]">{c.value}</p>
                )}
              </div>
              {c.copy && (
                <button
                  type="button"
                  class="copy-btn btn shrink-0"
                  data-copy={c.value}
                  style="padding:0.45rem 0.75rem;font-size:0.74rem;"
                >
                  copy
                </button>
              )}
            </div>
          ))
        }

        <!-- Socials -->
        <div class="card p-5">
          <span class="font-mono text-[0.72rem] uppercase tracking-wider text-[var(--accent)]">
            elsewhere
          </span>
          <div class="mt-3 flex flex-wrap gap-2">
            {
              socials.map((social) => (
                <a href={social.url} target="_blank" rel="noopener noreferrer" class="chip">
                  {social.label}
                </a>
              ))
            }
          </div>
        </div>
      </div>

      <!-- Terminal CTA -->
      <div class="flex flex-col gap-4">
        <TerminalWindow title="compose — new message">
          <div class="flex flex-col gap-2 font-mono text-sm">
            <p class="prompt">mail --to awadh</p>
            <p class="out text-[var(--fg-dim)]">to: awadhkishorsingh241@gmail.com</p>
            <p class="out text-[var(--fg-dim)]">subject: Let's work together</p>
            <p class="out text-[var(--fg-dim)]">status: <span class="text-[var(--accent)]">accepting messages</span></p>
            <p class="mt-2 text-[var(--muted)]"># click below to open your mail client</p>
          </div>
          <a href={mailtoCompose} class="btn btn-primary mt-5 w-full justify-center">
            ✉ open mail client
          </a>
        </TerminalWindow>

        <div class="card p-5">
          <p class="prompt text-xs">echo $AVAILABILITY</p>
          <p class="m-0 mt-2 text-sm text-[var(--fg-dim)]">
            Currently <span class="text-[var(--accent)]">available</span> for new opportunities —
            full-stack roles and select freelance projects. Based in Bengaluru, happy to work
            remotely.
          </p>
          <a
            href="/resume.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 inline-flex font-mono text-sm text-[var(--accent)] transition-colors hover:opacity-80"
          >
            ↓ download resume.pdf
          </a>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.copy;
      if (!text) return;
      try {
        await navigator.clipboard.writeText(text);
        const original = btn.textContent;
        btn.textContent = 'copied ✓';
        btn.style.color = 'var(--accent)';
        btn.style.borderColor = 'var(--accent)';
        setTimeout(() => {
          btn.textContent = original;
          btn.style.color = '';
          btn.style.borderColor = '';
        }, 1600);
      } catch {
        /* clipboard unavailable — no-op */
      }
    });
  });
</script>
