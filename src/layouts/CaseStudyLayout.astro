---
import PageLayout from './PageLayout.astro';

interface Props {
  name: string;
  tagline: string;
  description: string;
  role: string;
  status: string;
  stackSummary: string;
  live?: string;
  code?: string;
  links?: { label: string; url: string }[];
}

const { name, tagline, description, role, status, stackSummary, live, code, links } =
  Astro.props;

const meta = [
  { key: 'role', value: role },
  { key: 'status', value: status },
  { key: 'stack', value: stackSummary },
];
---

<PageLayout title={`${name} — Awadh Kishor Singh`} description={description}>
  <article class="wrap pt-12 md:pt-16">
    <a
      href="/projects"
      class="reveal reveal-1 inline-flex items-center gap-1.5 font-mono text-xs text-[var(--muted)] transition-colors hover:text-[var(--accent)]"
    >
      ← cd ../projects
    </a>

    <span class="eyebrow reveal reveal-1 mt-6 block">case study</span>
    <h1 class="reveal reveal-2 mt-3">{name}</h1>
    <p class="reveal reveal-2 mt-4 max-w-[64ch] text-base md:text-lg">{tagline}</p>

    <!-- Meta -->
    <div class="reveal reveal-3 mt-8 grid gap-3 sm:grid-cols-3">
      {
        meta.map((m) => (
          <div class="card p-5">
            <span class="font-mono text-[0.72rem] uppercase tracking-wider text-[var(--accent)]">
              {m.key}
            </span>
            <p class="m-0 mt-1.5 text-sm font-medium text-[var(--fg)]">{m.value}</p>
          </div>
        ))
      }
    </div>

    <!-- Body -->
    <div class="reveal reveal-4 case-body mt-14 flex flex-col gap-12">
      <slot />
    </div>

    <!-- Footer links -->
    <div class="mt-14 flex flex-wrap gap-3 border-t border-[var(--border)] pt-8">
      {
        links && links.length > 0
          ? links.map((l) => (
              <a href={l.url} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
                {l.label}
              </a>
            ))
          : live && (
              <a href={live} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
                visit live site ↗
              </a>
            )
      }
      {
        code && (
          <a href={code} target="_blank" rel="noopener noreferrer" class="btn">
            view code ↗
          </a>
        )
      }
      <a href="/projects" class="btn">← all projects</a>
      <a href="/contact" class="btn">get in touch</a>
    </div>
  </article>
</PageLayout>

<style is:global>
  .case-body section > h2 {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    font-size: 1.35rem;
    margin-bottom: 1.15rem;
  }
  .case-body section > h2::before {
    content: '##';
    color: var(--accent);
    font-size: 1rem;
  }
  /* consistent gap between any heading and the content that follows it */
  .case-body section > h2 + * {
    margin-top: 0;
  }
  .case-body section > p {
    line-height: 1.75;
  }
</style>
