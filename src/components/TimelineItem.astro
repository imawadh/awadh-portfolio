---
interface Props {
  type: 'work' | 'education';
  title: string;
  company: string;
  meta: string;
  date: string;
  current?: boolean;
  points?: string[];
  tags?: string[];
}

const { type, title, company, meta, date, current = false, points = [], tags = [] } = Astro.props;
const isWork = type === 'work';
---

<div class="relative pl-8 md:pl-10">
  <!-- Timeline rail -->
  <span class="absolute left-[7px] top-2 bottom-[-2.5rem] w-px bg-[var(--border)] last:hidden md:left-[9px]"></span>
  <!-- Node -->
  <span
    class={`absolute left-0 top-1.5 inline-flex h-3.5 w-3.5 items-center justify-center rounded-full border-2 md:h-[19px] md:w-[19px] ${
      current
        ? 'border-[var(--accent)] bg-[var(--accent)]'
        : 'border-[var(--border-bright)] bg-[var(--surface)]'
    }`}
  >
    {current && <span class="h-1.5 w-1.5 rounded-full bg-[var(--bg)]"></span>}
  </span>

  <div class="card p-6">
    <div class="flex flex-wrap items-center gap-2.5">
      <span
        class={`inline-flex items-center gap-1.5 rounded-md border px-2 py-0.5 font-mono text-[0.65rem] uppercase tracking-wider ${
          isWork
            ? 'border-[var(--accent-2)] bg-[rgba(74,222,128,0.08)] text-[var(--accent)]'
            : 'border-[var(--border-bright)] bg-[var(--bg-2)] text-[var(--muted)]'
        }`}
      >
        {isWork ? 'work' : 'education'}
      </span>
      <span class="font-mono text-xs text-[var(--muted)]">{date}</span>
      {current && (
        <span class="ml-auto font-mono text-[0.68rem] text-[var(--accent)]">● current</span>
      )}
    </div>

    <h3 class="mt-3.5 text-lg">{title}</h3>
    <p class="m-0 mt-0.5 font-mono text-sm text-[var(--accent)]">
      {company} <span class="text-[var(--muted)]">· {meta}</span>
    </p>

    {points.length > 0 && (
      <ul class="mt-4 flex flex-col gap-2">
        {points.map((point) => (
          <li class="flex gap-2.5 text-sm leading-relaxed text-[var(--fg-dim)]">
            <span class="mt-1 font-mono text-[var(--accent)]">▸</span>
            <span>{point}</span>
          </li>
        ))}
      </ul>
    )}

    {tags.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-1.5">
        {tags.map((tag) => <span class="chip">{tag}</span>)}
      </div>
    )}
  </div>
</div>
