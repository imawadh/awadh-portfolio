---
interface Props {
  index: string;
  name: string;
  tagline: string;
  description: string;
  tags: string[];
  status: string;
  live?: string;
  code?: string;
  caseStudy?: string;
}

const { index, name, tagline, description, tags, status, live, code, caseStudy } = Astro.props;
const href = caseStudy ?? live ?? code ?? '#';
---

<article class="card card-link flex flex-col overflow-hidden">
  <!-- Window header -->
  <div class="term-bar">
    <span class="dot dot-r"></span>
    <span class="dot dot-y"></span>
    <span class="dot dot-g"></span>
    <span class="term-title">{name.toLowerCase().replace(/[^a-z0-9]/g, '-')}.app</span>
    <span class="ml-auto font-mono text-[0.68rem] text-[var(--accent)]">● {status}</span>
  </div>

  <div class="flex flex-1 flex-col gap-4 p-6">
    <div class="flex items-baseline gap-2.5">
      <span class="font-mono text-sm text-[var(--muted)]">{index}</span>
      <h3 class="m-0 text-lg">
        <a href={href} class="transition-colors duration-200 hover:text-[var(--accent)]">{name}</a>
      </h3>
    </div>

    <p class="m-0 font-mono text-[0.82rem] text-[var(--accent)]">{tagline}</p>

    <p class="m-0 text-sm leading-relaxed text-[var(--fg-dim)]">{description}</p>

    <div class="flex flex-wrap gap-1.5">
      {tags.map((tag) => <span class="chip">{tag}</span>)}
    </div>

    <div class="mt-auto flex flex-wrap gap-2 pt-2">
      {caseStudy && (
        <a href={caseStudy} class="btn btn-primary" style="padding:0.5rem 0.9rem;font-size:0.78rem;">
          read case study →
        </a>
      )}
      {live && (
        <a href={live} target="_blank" rel="noopener noreferrer" class="btn" style="padding:0.5rem 0.9rem;font-size:0.78rem;">
          live ↗
        </a>
      )}
      {code && (
        <a href={code} target="_blank" rel="noopener noreferrer" class="btn" style="padding:0.5rem 0.9rem;font-size:0.78rem;">
          code ↗
        </a>
      )}
    </div>
  </div>
</article>
