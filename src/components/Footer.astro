---
import { socials } from '../utils/socials';
import { resumeUrl } from '../utils/site';

const navItems = [
  { label: 'about', href: '/about' },
  { label: 'experience', href: '/experience' },
  { label: 'projects', href: '/projects' },
  { label: 'skills', href: '/skills' },
  { label: 'certifications', href: '/certifications' },
  { label: 'contact', href: '/contact' },
];

const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-[var(--border)] bg-[var(--bg-2)]">
  <div class="wrap py-16 md:py-20">
    <!-- CTA -->
    <div class="flex flex-col gap-8 border-b border-[var(--border)] pb-14 md:flex-row md:items-end md:justify-between">
      <div class="max-w-xl">
        <span class="eyebrow">let's build</span>
        <h2 class="mt-3">
          Got a project or a role
          <br />
          <span class="text-[var(--accent)]">in mind?</span>
        </h2>
        <p class="mt-3 text-[0.95rem]">
          I'm open to full-stack and software engineering roles, plus a small number of freelance builds.
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a href="/contact" class="btn btn-primary">↳ say hello</a>
        <a href={resumeUrl} target="_blank" rel="noopener noreferrer" class="btn">↓ resume.pdf</a>
      </div>
    </div>

    <!-- Columns -->
    <div class="grid gap-10 py-14 md:grid-cols-[1.6fr_1fr_1fr]">
      <div>
        <div class="inline-flex items-center gap-2.5">
          <span class="inline-flex h-7 w-7 items-center justify-center rounded-md border border-[var(--border-bright)] bg-[var(--surface)] font-mono text-sm font-bold text-[var(--accent)]">
            ~
          </span>
          <span class="font-mono text-sm text-[var(--fg)]">Awadh Kishor Singh</span>
        </div>
        <p class="mt-4 max-w-sm text-sm leading-relaxed">
          Full Stack Developer building production-ready web applications from Bengaluru.
          Currently interning at IAVerse and studying Data Science at IIT Madras.
        </p>
        <div class="mt-5 inline-flex items-center gap-2 rounded-md border border-[var(--border)] bg-[var(--surface)] px-3 py-1.5">
          <span class="relative inline-flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[var(--accent)] opacity-60"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-[var(--accent)]"></span>
          </span>
          <span class="font-mono text-[0.72rem] text-[var(--fg-dim)]">available for work</span>
        </div>
      </div>

      <div>
        <p class="prompt mb-3 text-xs">ls ./pages</p>
        <ul class="flex flex-col gap-2">
          {
            navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="font-mono text-sm text-[var(--fg-dim)] transition-colors duration-200 hover:text-[var(--accent)]"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <p class="prompt mb-3 text-xs">ls ./socials</p>
        <ul class="flex flex-col gap-2">
          {
            socials.map((social) => (
              <li>
                <a
                  href={social.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group inline-flex items-center gap-1.5 font-mono text-sm text-[var(--fg-dim)] transition-colors duration-200 hover:text-[var(--accent)]"
                >
                  {social.label}
                  <span class="text-[var(--muted)] opacity-0 transition-opacity group-hover:opacity-100">↗</span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="border-t border-[var(--border)] pt-7 font-mono text-xs text-[var(--muted)]">
      <p>// © {year} Awadh Kishor Singh — all rights reserved</p>
    </div>
  </div>
</footer>
