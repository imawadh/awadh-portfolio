---
interface Props {
  title?: string;
  class?: string;
}

const { title = 'bash — ~/awadh', class: cls = '' } = Astro.props;
---

<div class={`term ${cls}`}>
  <div class="term-bar">
    <span class="dot dot-r"></span>
    <span class="dot dot-y"></span>
    <span class="dot dot-g"></span>
    <span class="term-title">{title}</span>
  </div>
  <div class="term-body">
    <slot />
  </div>
</div>
