---
import { socials } from '../utils/socials';

interface NavItem {
  label: string;
  href: string;
  index: string;
}

const navItems: NavItem[] = [
  { label: 'about', href: '/about', index: '01' },
  { label: 'experience', href: '/experience', index: '02' },
  { label: 'projects', href: '/projects', index: '03' },
  { label: 'skills', href: '/skills', index: '04' },
  { label: 'certifications', href: '/certifications', index: '05' },
  { label: 'contact', href: '/contact', index: '06' },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<nav
  id="siteNav"
  class="sticky top-0 z-50 border-b border-[var(--border)] bg-[rgba(10,13,18,0.82)] backdrop-blur-xl"
>
  <div class="wrap flex items-center justify-between py-3.5">
    <!-- Brand -->
    <a href="/" class="group inline-flex items-center gap-2.5" aria-label="Awadh — home">
      <span class="inline-flex h-7 w-7 items-center justify-center rounded-md border border-[var(--border-bright)] bg-[var(--surface)] font-mono text-sm font-bold text-[var(--accent)] transition-colors duration-300 group-hover:border-[var(--accent)]">
        ~
      </span>
      <span class="font-mono text-sm text-[var(--fg-dim)]">
        <span class="text-[var(--accent)]">awadh</span><span class="text-[var(--muted)]">@</span>portfolio
      </span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden items-center gap-1 md:flex">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? 'page' : undefined}
            class={`rounded-md px-2.5 py-1.5 font-mono text-[0.82rem] transition-colors duration-200 hover:text-[var(--accent)] ${
              isActive(item.href) ? 'text-[var(--accent)]' : 'text-[var(--fg-dim)]'
            }`}
          >
            <span class="text-[var(--muted)]">{item.index}.</span>
            {item.label}
          </a>
        ))
      }
      <a
        href="/contact"
        class="ml-2 inline-flex items-center gap-2 rounded-md border border-[var(--border-bright)] bg-[var(--surface)] py-1.5 pl-2.5 pr-3 font-mono text-[0.76rem] text-[var(--fg-dim)] transition-colors duration-300 hover:border-[var(--accent)]"
      >
        <span class="relative inline-flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[var(--accent)] opacity-60"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-[var(--accent)]"></span>
        </span>
        available
      </a>
    </div>

    <!-- Mobile toggle -->
    <button
      id="navToggle"
      type="button"
      aria-label="Toggle navigation"
      aria-expanded="false"
      aria-controls="navMenu"
      class="nav-toggle inline-flex h-9 items-center gap-2 rounded-md border border-[var(--border-bright)] bg-[var(--surface)] px-3 font-mono text-xs text-[var(--fg)] transition-colors duration-300 hover:border-[var(--accent)] md:hidden"
    >
      <span class="toggle-label-closed">menu</span>
      <span class="toggle-label-open text-[var(--accent)]">close</span>
      <span class="relative flex h-3.5 w-4 flex-col items-center justify-center">
        <span class="bar bar-top absolute h-[2px] w-4 rounded-full bg-current transition-transform duration-300"></span>
        <span class="bar bar-bot absolute h-[2px] w-4 rounded-full bg-current transition-transform duration-300"></span>
      </span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="navMenu"
    class="nav-menu invisible absolute left-0 right-0 top-full max-h-[calc(100dvh-3.5rem)] origin-top -translate-y-2 overflow-y-auto border-b border-[var(--border)] bg-[var(--bg-2)] opacity-0 transition-all duration-300 ease-out md:hidden"
  >
    <div class="wrap py-6">
      <p class="prompt mb-3 text-xs">cd ~/</p>
      <ul class="flex flex-col">
        {
          navItems.map((item) => (
            <li class="border-t border-[var(--border)] last:border-b">
              <a
                href={item.href}
                aria-current={isActive(item.href) ? 'page' : undefined}
                class={`group/item flex items-center justify-between py-3.5 font-mono transition-colors duration-200 ${
                  isActive(item.href) ? 'text-[var(--accent)]' : 'text-[var(--fg)]'
                }`}
              >
                <span class="text-lg">
                  <span class="text-[var(--muted)] text-sm">{item.index}.</span>
                  {' '}
                  {item.label}
                </span>
                <span class="text-[var(--accent)] opacity-50 transition-opacity group-hover/item:opacity-100">
                  →
                </span>
              </a>
            </li>
          ))
        }
      </ul>

      <div class="mt-6">
        <p class="prompt mb-2 text-xs">ls ./socials</p>
        <div class="flex flex-wrap gap-2">
          {
            socials.map((social) => (
              <a
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
                class="chip"
              >
                {social.label}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</nav>

<style>
  .nav-toggle .bar-top {
    transform: translateY(-3px);
  }
  .nav-toggle .bar-bot {
    transform: translateY(3px);
  }
  .nav-toggle[aria-expanded='true'] .bar-top {
    transform: translateY(0) rotate(45deg);
  }
  .nav-toggle[aria-expanded='true'] .bar-bot {
    transform: translateY(0) rotate(-45deg);
  }
  .nav-toggle[aria-expanded='true'] .toggle-label-closed {
    display: none;
  }
  .nav-toggle[aria-expanded='false'] .toggle-label-open {
    display: none;
  }
  .nav-menu.is-open {
    visibility: visible;
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const nav = document.getElementById('siteNav');
  const navToggle = document.getElementById('navToggle');
  const navMenu = document.getElementById('navMenu');

  const setOpen = (open: boolean) => {
    if (!navToggle || !navMenu) return;
    navToggle.setAttribute('aria-expanded', String(open));
    navMenu.classList.toggle('is-open', open);
    document.body.style.overflow = open ? 'hidden' : '';
  };

  navToggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    setOpen(navToggle.getAttribute('aria-expanded') !== 'true');
  });

  navMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => setOpen(false));
  });

  document.addEventListener('click', (e) => {
    if (!nav?.contains(e.target as Node)) setOpen(false);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setOpen(false);
  });
</script>
