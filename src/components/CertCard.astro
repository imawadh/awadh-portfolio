---
interface Props {
  index: string;
  date: string;
  title: string;
  issuer: string;
  details: string;
  url: string;
}

const { index, date, title, issuer, details, url } = Astro.props;
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="card card-link group flex flex-col gap-3 p-6 md:flex-row md:items-center md:justify-between"
>
  <div class="flex gap-4">
    <span class="font-mono text-sm text-[var(--muted)]">{index}</span>
    <div class="flex flex-col gap-1">
      <span class="font-mono text-[0.7rem] uppercase tracking-wider text-[var(--accent)]">{date}</span>
      <h3 class="m-0 text-base transition-colors duration-200 group-hover:text-[var(--accent)]">
        {title}
      </h3>
      <p class="m-0 font-mono text-[0.82rem] text-[var(--fg-dim)]">{issuer}</p>
      <p class="m-0 text-sm text-[var(--muted)]">{details}</p>
    </div>
  </div>
  <span class="shrink-0 font-mono text-xs text-[var(--muted)] transition-colors duration-200 group-hover:text-[var(--accent)] md:pl-4">
    verify ↗
  </span>
</a>
