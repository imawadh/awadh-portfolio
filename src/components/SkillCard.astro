---
interface Props {
  index: string;
  category: string;
  command: string;
  skills: string[];
}

const { index, category, command, skills } = Astro.props;
---

<div class="card p-6">
  <div class="flex items-baseline justify-between gap-3">
    <h3 class="m-0 text-base">
      <span class="text-[var(--muted)]">{index}</span> {category}
    </h3>
    <span class="font-mono text-[0.7rem] text-[var(--muted)]">{skills.length} items</span>
  </div>
  <p class="prompt mt-1 text-xs">{command}</p>
  <div class="mt-4 flex flex-wrap gap-2">
    {skills.map((skill) => <span class="chip">{skill}</span>)}
  </div>
</div>
