# ── Environment variables ───────────────────────────────────────────────
# Copy this file to `.env` and fill in the values, or set them in your
# hosting provider (e.g. Vercel → Project Settings → Environment Variables).
#
# Vars must be prefixed with PUBLIC_ to be available in the built site.

# Public URL to your résumé PDF — e.g. a Google Drive share link.
# For Drive: open the file → Share → "Anyone with the link" → Copy link.
PUBLIC_RESUME_URL=https://drive.google.com/file/d/YOUR_FILE_ID/view
